---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { translations } from "../../../i18n/translations";

const t = translations.de;
const posts = (
  await getCollection("blog", ({ id }) => id.startsWith("de/"))
).sort((a, b) => b.data.pubDate!.valueOf() - a.data.pubDate!.valueOf());
---

<style>
  .container {
    max-width: 56rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    h1 {
      font-size: 3rem;
    }
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  article a {
    display: block;
  }

  .post-content {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  time {
    color: #888;
    font-size: 0.875rem;
    font-weight: 500;
    min-width: 100px;
  }

  .post-text {
    flex: 1;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  article:hover h2 {
    color: #0066cc;
  }

  .description {
    color: #666;
    line-height: 1.6;
  }
</style>

<Layout title={`${t.blog.title} - Marco Schneider`} lang="de">
  <div class="container">
    <h1>
      {t.blog.title}
    </h1>

    <div class="posts-list">
      {
        posts.map((post) => (
          <article>
            <a href={`/de/blog/${post.slug.replace("de/", "")}`}>
              <div class="post-content">
                <time>
                  {post.data.pubDate?.toLocaleDateString("de-DE", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                <div class="post-text">
                  <h2>
                    {post.data.title}
                  </h2>
                  <p class="description">
                    {post.data.description}
                  </p>
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</Layout>
