---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { translations } from "../../../i18n/translations";

const t = translations.en;

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ id }) => id.startsWith("en/"));
  return posts.map((post) => ({
    params: { slug: post.slug.replace("en/", "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<style>
  article {
    max-width: 48rem;
  }

  header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    h1 {
      font-size: 3rem;
    }
  }

  time {
    color: #888;
  }

  .prose {
    color: #666;
    font-size: 1.125rem;
    line-height: 1.75;
  }

  .prose :global(h2) {
    color: #333;
    font-weight: bold;
    font-size: 1.875rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(h3) {
    color: #333;
    font-weight: bold;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(a) {
    color: #0066cc;
    text-decoration: none;
  }

  .prose :global(a:hover) {
    text-decoration: underline;
  }

  .prose :global(strong) {
    color: #333;
    font-weight: 600;
  }

  .prose :global(code) {
    color: #4ade80;
    background: #f5f5f5;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .prose :global(pre) {
    background: #f5f5f5;
    border: 1px solid #ddd;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: #333;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.5rem 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid #0066cc;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #666;
  }

  footer {
    margin-top: 4rem;
    padding-top: 2rem;
  }

  footer a {
    color: #0066cc;
    font-weight: 500;
  }

  footer a:hover {
    text-decoration: underline;
  }
</style>

<Layout title={post.data.title!} lang="en">
  <article>
    <header>
      <h1>
        {post.data.title}
      </h1>
      <time>
        {
          post.data.pubDate?.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer>
      <a href="/en/blog">
        ← {t.blog.backToAll}
      </a>
    </footer>
  </article>
</Layout>
