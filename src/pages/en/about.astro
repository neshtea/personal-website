---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { translations } from "../../i18n/translations";
import profile from "../../images/profile.jpg";

const t = translations.en;
---

<style>
  article {
    max-width: 48rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    h1 {
      font-size: 3rem;
    }
  }

  .content {
    color: #666;
    font-size: 1.125rem;
    line-height: 1.6;
  }

  .content p {
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .grid p {
    padding-right: 1.25rem;
  }

  img {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
  }

  .content a {
    color: #0066cc;
  }

  .content a:hover {
    text-decoration: underline;
  }
</style>

<Layout title={`${t.about.title} - Marco Schneider`} lang="en">
  <article>
    <h1>
      {t.about.title}
    </h1>

    <div class="content">
      <div class="grid">
        <p>
          I'm Marco Schneider, I live in Vienna, Austria, and I write software.
          I work at <a
            href="https://active-group.de">Active Group GmbH</a
          >, one of the leading providers of custom software using functional
          programming in Germany as a software architect, developer and <a
            href="https://active-group.de/team/marco-schneider/"
            >chief technology facilitator</a
          >. At Active Group, I work on different projects utilising a variety
          of technologies and architectures. In addition, I teach functional
          programming and functional software architecture in workshops and
          speak about it at conferences. I'm a certified trainer for the iSAQB
          CSPA-A module <a
            href="https://www.isaqb.org/certifications/cpsa-certifications/cpsa-advanced-level/funar-functional-software-architecture/?ref=defmarco.com"
            >FUNAR - Functional Software Architecture</a
          >.
        </p>
        <Image
          src={profile}
          alt="Profile picture of Marco, wearing sunglasses and a brown dress shirt. The image is intentionally blurry."
        />
      </div>
      <h2>Programming</h2>
      <p>
        I'm interested in functional programming, functional software
        architecture and its application in the industry. I love Lisp-languages
        such as Clojure(Script), Scheme or Common Lisp and ML-decendants (OCaml,
        Haskell, …). In general, I prefer languages that afford the use of
        functional programming techniques, which includes Erlang/Elixir,
        ECMA-script and more. For some time now I'm also interested in nix and
        reproducible builds and delivery of software.
      </p>
      <p>
        Every now and then I contribute to <a
          href="https://funktionale-programmierung.de"
          >funktionale-programmierung.de</a
        > — the largest German language blog on all things functional programming.
      </p>
    </div>
  </article>
</Layout>
