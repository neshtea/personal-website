---
import Layout from "../../layouts/Layout.astro";
import { translations } from "../../i18n/translations";
import { publications, workshops, talks } from "../../content/publications";

const t = translations.en;
---

<style>
  .container {
    max-width: 56rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    h1 {
      font-size: 3rem;
    }
  }

  section {
    margin-bottom: 5rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 2rem;
    color: #0066cc;
  }

  .items-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  article {
    border-left: 2px solid #4ade80;
    padding-left: 1.5rem;
  }

  article:hover {
    border-left-color: #0066cc;
  }

  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .authors,
  .event {
    color: #666;
    margin-bottom: 0.25rem;
  }

  .venue,
  .location {
    color: #888;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .description-text {
    color: #666;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .links {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
  }

  .links a {
    color: #0066cc;
    font-weight: 500;
  }

  .links a:hover {
    color: #0052a3;
  }
</style>

<Layout title={`${t.publications.title} - Marco Schneider`} lang="en">
  <div class="container">
    <h1>
      {t.publications.title}
    </h1>

    <section>
      <h2>
        {t.publications.publications}
      </h2>
      <div class="items-list">
        {
          publications.map((pub) => (
            <article>
              <h3>
                {pub.title}
              </h3>
              <p class="authors">{pub.authors}</p>
              <p class="venue">{pub.venue}</p>
              <div class="links">
                {Object.entries(pub.links).map(([type, url]) => (
                  <a href={url}>
                    [{type}]
                  </a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <h2>
        Workshops
      </h2>
      <div class="items-list">
        {
          workshops.map((workshop) => (
            <article>
              <h3>
                {workshop.title}
              </h3>
              <p class="authors">{workshop.venue}</p>
              <p class="description-text">
                 {workshop.description.en}
              </p>
              <p class="location">
                {workshop.location} · {workshop.date}
              </p>
              <div class="links">
                {Object.entries(workshop.links).map(([type, url]) => (
                  <a href={url}>
                    [{type}]
                  </a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <h2>
        {t.publications.talks}
      </h2>
      <div class="items-list">
        {
          talks.map((talk) => (
            <article>
              <h3>
                {talk.title}
              </h3>
              <p class="event">{talk.event}</p>
              <p class="location">
                {talk.location} · {talk.date}
              </p>
              <div class="links">
                {Object.entries(talk.links).map(([type, url]) => (
                  <a href={url}>
                    [{type}]
                  </a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
