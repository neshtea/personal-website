---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { translations } from "../../i18n/translations";

const t = translations.en;
const recentPosts = (
  await getCollection("blog", ({ id }) => id.startsWith("en/"))
)
  .sort((a, b) => b.data.pubDate!.valueOf() - a.data.pubDate!.valueOf())
  .slice(0, 3);
---

<style>
  .hero {
    padding: 3rem 0;
  }

  h1 {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    h1 {
      font-size: 3.75rem;
    }
  }

  .accent {
    color: #0066cc;
  }

  .intro {
    font-size: 1.25rem;
    color: #666;
    line-height: 1.6;
    max-width: 48rem;
  }

  .section {
    margin-top: 6rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: bold;
  }

  .view-all {
    color: #0066cc;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  article {
    display: block;
  }

  .post-content {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  time {
    color: #888;
    font-size: 0.875rem;
    font-weight: 500;
    min-width: 100px;
  }

  .post-text {
    flex: 1;
  }

  h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  article:hover h3 {
    color: #0066cc;
  }

  .description {
    color: #666;
    line-height: 1.6;
  }
</style>

<Layout title="Marco Schneider" lang="en">
  <div>
    <!-- Hero section -->
    <section class="hero">
      <h1>
        {t.home.hello}
        <span class="accent">Marco Schneider</span>
      </h1>
      <p class="intro">
        {t.home.intro}
      </p>
    </section>

    <!-- Recent posts -->
    <section class="section">
      <div class="section-header">
        <h2>{t.home.recentPosts}</h2>
        <a href="/en/blog" class="view-all">
          {t.home.viewAll} →
        </a>
      </div>

      <div class="posts-grid">
        {
          recentPosts.map((post) => (
            <article>
              <a
                href={`/en/blog/${post.slug.replace("en/", "")}`}
              >
                <div class="post-content">
                  <time>
                    {post.data.pubDate?.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                  <div class="post-text">
                    <h3>
                      {post.data.title}
                    </h3>
                    <p class="description">
                      {post.data.description}
                    </p>
                  </div>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
