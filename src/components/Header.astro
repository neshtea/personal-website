---
const { lang, currentPath, translations } = Astro.props;
---
<style>
  header {
    border-bottom: 1px solid #ddd;
    position: sticky;
    top: 0;
    background: #fff;
  }

  .header-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: bold;
    color: #333;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    font-size: 0.875rem;
  }

  .nav-link {
    color: #666;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #0066cc;
  }

  .lang-switcher {
    display: flex;
    gap: 0.5rem;
    border-left: 1px solid #ddd;
    padding-left: 1.5rem;
  }

  .lang-link {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .lang-link.active {
    background: #0066cc;
    color: #fff;
  }

  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    width: 1.5rem;
    height: 1.5rem;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu-btn span {
    display: block;
    width: 1.5rem;
    height: 2px;
    background: #333;
    transition: all 0.3s;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none !important;
    }
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-menu .nav-list {
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu .nav-link {
    display: block;
    padding: 0.5rem 0;
  }

  .mobile-menu .lang-switcher {
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid #ddd;
    border-left: none;
    padding-left: 0;
  }

  .mobile-menu .lang-link {
    padding: 0.5rem 0.75rem;
  }
</style>

<header>
  <div class="header-container">
    <nav>
      <a href={`/${lang}`} class="logo">
        Marco Schneider
      </a>

      <!-- Desktop Navigation -->
      <div class="desktop-nav">
        <ul class="nav-list">
          <li>
            <a
              href={`/${lang}/about`}
              class={`nav-link ${currentPath.includes("/about") ? "active" : ""}`}
            >
              {translations.nav.about}
            </a>
          </li>
          <li>
            <a
              href={`/${lang}/publications`}
              class={`nav-link ${currentPath.includes("/publications") ? "active" : ""}`}
            >
              {translations.nav.publications}
            </a>
          </li>
          <li>
            <a
              href={`/${lang}/blog`}
              class={`nav-link ${currentPath.includes("/blog") ? "active" : ""}`}
            >
              {translations.nav.blog}
            </a>
          </li>
          <li>
            <a
              href={`/${lang}/contact`}
              class={`nav-link ${currentPath.includes("/contact") ? "active" : ""}`}
            >
              {translations.nav.contact}
            </a>
          </li>
        </ul>
        <!-- Language switcher -->
        <div class="lang-switcher">
          <a
            href={currentPath.replace(`/${lang}`, "/de")}
            class={`lang-link ${lang === "de" ? "active" : ""}`}
          >
            DE
          </a>
          <a
            href={currentPath.replace(`/${lang}`, "/en")}
            class={`lang-link ${lang === "en" ? "active" : ""}`}
          >
            EN
          </a>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="mobile-menu">
      <ul class="nav-list">
        <li>
          <a
            href={`/${lang}/about`}
            class={`nav-link ${currentPath.includes("/about") ? "active" : ""}`}
          >
            {translations.nav.about}
          </a>
        </li>
        <li>
          <a
            href={`/${lang}/publications`}
            class={`nav-link ${currentPath.includes("/publications") ? "active" : ""}`}
          >
            {translations.nav.publications}
          </a>
        </li>
        <li>
          <a
            href={`/${lang}/blog`}
            class={`nav-link ${currentPath.includes("/blog") ? "active" : ""}`}
          >
            {translations.nav.blog}
          </a>
        </li>
        <li>
          <a
            href={`/${lang}/contact`}
            class={`nav-link ${currentPath.includes("/contact") ? "active" : ""}`}
          >
            {translations.nav.contact}
          </a>
        </li>
      </ul>
      <!-- Mobile Language switcher -->
      <div class="lang-switcher">
        <a
          href={currentPath.replace(`/${lang}`, "/de")}
          class={`lang-link ${lang === "de" ? "active" : ""}`}
        >
          DE
        </a>
        <a
          href={currentPath.replace(`/${lang}`, "/en")}
          class={`lang-link ${lang === "en" ? "active" : ""}`}
        >
          EN
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    
    if (isOpen) {
      mobileMenu?.classList.remove('open');
    } else {
      mobileMenu?.classList.add('open');
    }
    
    // Animate burger to X
    const spans = menuBtn?.querySelectorAll('span');
    if (spans) {
      if (isOpen) {
        spans[0].style.transform = 'rotate(0)';
        spans[1].style.opacity = '1';
        spans[2].style.transform = 'rotate(0)';
      } else {
        spans[0].style.transform = 'translateY(8px) rotate(45deg)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'translateY(-8px) rotate(-45deg)';
      }
    }
  });
</script>
